

for i in range(3):
    print("The value of i is ", i)
    for j in range(3):
        print("The value of j is ", j)

r=7
for i in range(1,r+1):
        print(" " * (r-i),end="")
        print("*" * (2*i-1))

def greet():
    print("Hello, welcome to the world of programming!")    
        
greet()